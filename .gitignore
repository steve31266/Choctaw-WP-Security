# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Editor / IDE local settings
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Cursor (local AI/editor state — keep plans if you want them in git)
.cursor/

# Secrets and environment files (never commit these)
.env
.env.*
*.pem
*.key

# Logs and temp files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies (if you add them later)
/vendor/
/node_modules/

# Build/output artifacts (if you add them later)
/dist/
/build/

# PHPUnit / test coverage (if you add tests later)
.phpunit.result.cache
/coverage/

# Archives
*.zip
*.tar.gz
